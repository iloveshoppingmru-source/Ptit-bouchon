              </div>
            ))}
          </div>
        </Card>
      )}
      {/* FAQ */}
      {faqs?.length>0&&(
        <Card title="❓ FAQ">
          {faqs.map((f,i)=>(
            <div key={f.id} style={{borderBottom:i<faqs.length-1?`1px solid ${theme.border}`:"none",paddingBottom:10,marginBottom:10}}>
              <button onClick={()=>setOpenFaq(openFaq===f.id?null:f.id)}
